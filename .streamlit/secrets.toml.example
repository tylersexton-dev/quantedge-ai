# .streamlit/secrets.toml.example
#
# ── HOW TO USE ON STREAMLIT CLOUD ─────────────────────────────────────────────
#
# 1. Go to share.streamlit.io → your app → Settings → Secrets
# 2. Paste the line(s) below (with your real values) into the secrets editor
# 3. Click Save — the app will restart and pick them up automatically
#
# DO NOT commit a real secrets.toml to Git. This file is an example only.
# The actual secrets.toml is listed in .gitignore.
#
# ── Keys ──────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY = "sk-ant-your-key-here"

# Get your key at: https://console.anthropic.com
# Create → API Keys → New Key → copy value starting with sk-ant-
