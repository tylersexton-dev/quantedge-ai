# QuantEdge AI — Environment Variables
# Copy this file to .env and fill in your values

# ── Anthropic API Key (required for AI analyst features) ──────────────────────
# Get your key at: https://console.anthropic.com
# Create a new key under "API Keys" — starts with sk-ant-
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional: Override default model ──────────────────────────────────────────
# Default is claude-opus-4-5. You can switch to claude-sonnet for faster/cheaper responses.
# ANTHROPIC_MODEL=claude-sonnet-4-5
